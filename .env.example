# Postgres connection (matches docker-compose.yml)
DATABASE_URL="postgresql://doula:doula@localhost:5432/doula_billing"

# Clearinghouse adapter: mock | claimmd | stedi
CLEARINGHOUSE=mock

# Required when CLEARINGHOUSE=claimmd
# CLAIMMD_ACCOUNT_KEY=

# Required when CLEARINGHOUSE=stedi
# STEDI_API_KEY=

# Shared secret expected on the clearinghouse webhook (placeholder scheme;
# replace with the vendor's real signature verification when wiring one)
# CLEARINGHOUSE_WEBHOOK_SECRET=
